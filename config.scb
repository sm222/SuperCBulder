NAME:scb

CC:gcc

debug:-g

default: 
  -D=HELLO


test:
  %LINUX   -D VAR=A
  %WINDOWS -D VAR=B
  %MAC     -D VAR=C
  %DEFAULT -D VAR=D

# if no default and no case is catch var woud be empty


foo:1

bar:2
  %baz

baz:3
 %foo

ING:
  test


PROG:
  %debug
  %default

DEP:
  @echo foo %foo bar %bar baz %baz
