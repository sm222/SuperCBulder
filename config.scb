NAME:scb

CC:gcc

debug:-g

default:
  -D=HELLO


test:
  %_LINUX   -D VAR=A
  %_WINDOWS -D VAR=B
  %_MAC     -D VAR=C
  %_DEFAULT -D VAR=D

# if no default and no case is catch var woud be empty


foo:A

bar:B
  %baz

baz:C
  %foo\wd
  %test
  !%_ROOT!

ING:


PROG:
  %debug 
  %default 

sys:
  %_LINUX linux heh 
  %_WINDOWS B
  %_MACOS C

DEP:
  echo foo %foo;
  echo bar %bar;
  echo baz %baz;
  %blah;
