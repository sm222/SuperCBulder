NAME:scb

CC:gcc

debug:-g

default: 
  -D=HELLO


test:
  %LINUX   -D VAR=A
  %WINDOWS -D VAR=B
  %MAC     -D VAR=C
  %DEFAULT -D VAR=D

# if no default and no case is catch var woud be empty



foo:A 

bar:B
  %baz 

baz:C
 %foo 

ING:
  test 


PROG:
  %debug 
  %default 

sys:
  %_LINUX linux heh 
  %_WINDOWS B
  %_MACOS C

DEP:
  echo foo %foo;
  echo bar %bar;
  echo baz %baz;
